{
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && VITE_API_URL=https://dash-logistics-api.vercel.app/api pnpm --filter @dash/logistics-admin build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "ignoreCommand": "bash ../../scripts/vercel/ignore-logistics-admin.sh"
}
